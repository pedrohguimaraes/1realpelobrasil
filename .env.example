# Postgres (Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Obrigatório em produção (NODE_ENV=production): POST /api/webhooks/pix exige o mesmo valor no header x-webhook-secret
# Em desenvolvimento, se vazio, o webhook aceita chamadas sem header (apenas para testes locais).
# WEBHOOK_SECRET=seu_segredo_longo_e_aleatorio
