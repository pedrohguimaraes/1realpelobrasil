# Postgres (Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# mock: QR Pix local sem gateway real
# abacatepay: cria cobrança PIX via Checkout Transparente da AbacatePay
# Se ficar vazio, usa abacatepay quando ABACATEPAY_API_KEY existir; caso contrário usa mock.
PIX_GATEWAY=mock

ABACATEPAY_API_KEY=
ABACATEPAY_API_BASE_URL=https://api.abacatepay.com/v2

# Campos enviados em data na criação do Checkout Transparente PIX.
# Placeholders aceitos na descrição: {voteId}, {candidateId}, {candidateName}, {amountCents}, {amountBRL}
ABACATEPAY_PIX_DESCRIPTION="Voto beneficente 1 Real pelo Brasil - {candidateName}"
ABACATEPAY_PIX_EXPIRES_IN=3600
ABACATEPAY_PIX_METADATA_JSON={}
ABACATEPAY_PIX_UTM_SOURCE=
ABACATEPAY_PIX_UTM_MEDIUM=
ABACATEPAY_PIX_UTM_CAMPAIGN=
ABACATEPAY_PIX_UTM_TERM=
ABACATEPAY_PIX_UTM_CONTENT=

# Configure o webhook da AbacatePay para:
# https://seu-dominio.com/api/webhooks/pix?webhookSecret=SEU_SECRET
ABACATEPAY_WEBHOOK_SECRET=
ABACATEPAY_WEBHOOK_REQUIRE_SIGNATURE=true
ABACATEPAY_WEBHOOK_HMAC_KEY=

# Em desenvolvimento o botão de simulação aparece por padrão.
# Em produção, só aparece se esta variável for true.
NEXT_PUBLIC_ENABLE_PIX_SIMULATION=false
